<configuration description="Config for Interactive CTS Permission UI test cases">
    <option name="test-suite-tag" value="cts-v-host" />
    <option name="config-descriptor:metadata" key="subplan" value="cts-v-host-interactive" />

    <target_preparer class="com.android.tradefed.targetprep.suite.SuiteApkInstaller">
        <option name="cleanup-apks" value="true" />
        <option name="install-arg" value="-t" />
        <option name="test-file-name" value="CtsPermissionInteractiveTestCases.apk" />
    </target_preparer>

    <target_preparer class="com.android.tradefed.targetprep.RunCommandTargetPreparer">
        <option name="run-command" value="mkdir -p /data/local/tmp/cts-permissionui" />
        <option name="teardown-command" value="rm -rf /data/local/tmp/cts-permissionui"/>
    </target_preparer>

    <target_preparer class="com.android.compatibility.common.tradefed.targetprep.FilePusher">
        <option name="push" value="CtsLocationButtonApp.apk->/data/local/tmp/cts-permissionui/CtsLocationButtonApp.apk" />
    </target_preparer>

    <target_preparer class="com.android.tradefed.targetprep.RunCommandTargetPreparer">
        <option name="run-command" value="appops set android.permissioninteractive.cts REQUEST_INSTALL_PACKAGES allow" />
        <option name="run-command" value="am wait-for-broadcast-barrier"  />
    </target_preparer>

    <test class="com.android.tradefed.testtype.AndroidJUnitTest" >
        <option name="package" value="android.permissioninteractive.cts" />
        <option name="include-annotation" value="com.android.interactive.annotations.Interactive" />
    </test>
</configuration>
