        <item name="scIssueTitleTextAppearance">
            @style/TextAppearance.SafetyCenter.Headline.Issue
        </item>
        <item name="scIssueSubtitleTextAppearance">
            @style/TextAppearance.SafetyCenter.IssueSubtitle
        </item>
        <item name="scIssueAttributionTitleTextAppearance">
            @style/TextAppearance.SafetyCenter.IssueAttribution
        </item>
        <item name="scMoreIssuesTitleTextAppearance">
            @style/TextAppearance.Material3.LabelLarge
        </item>
        <item name="scQsToggleTitleTextAppearance">
            @style/TextAppearance.SafetyCenter.Medium
