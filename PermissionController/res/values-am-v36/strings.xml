<resources xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:xliff="urn:oasis:names:tc:xliff:document:1.2">
    <string name="app_function_access_settings_title" msgid="6493844150240131544">"የሌሎች መተግበሪያዎች ወኪል ቁጥጥር"</string>
    <string name="app_function_access_settings_summary" msgid="4981985766883304913">"መሣሪያዎ እና ሌሎች መተግበሪያዎች ላይ ተግባሮችን ይፈጽሙ"</string>
    <string name="app_function_agent_list_summary" msgid="701511309529625652">"በመሣሪያዎ ላይ መተግበሪያዎች እና የመሣሪያ ተግባራትን መድረስ የሚችሉ የረዳት መተግበሪያዎች"</string>
    <string name="app_function_agent_list_empty" msgid="4470415933968048626">"በአሁኑ ጊዜ ማናቸውም ተወካይ መተግበሪያዎች የሉዎትም።"</string>
    <string name="app_function_agent_access_summary" msgid="232294957355918509">"የመተግበሪያዎች እና የሥርዓት ቅንብሮች <xliff:g id="APP_NAME">%1$s</xliff:g> እርምጃዎችን ለመከወን መድረስ ይችላሉ"</string>
    <string name="app_function_agent_access_empty" msgid="4726736137938790465">"በአሁኑ ጊዜ ማናቸውም ዒላማ የሚደረግባቸው መተግበሪያዎች የሉዎትም።"</string>
    <string name="app_function_target_access_title" msgid="3033806413829781590">"የ<xliff:g id="APP_NAME">%1$s</xliff:g> የተወካይ ቁጥጥር"</string>
    <string name="app_function_target_access_summary" msgid="3371340975017149274">"እነዚህ ተወካዮች <xliff:g id="APP_NAME">%1$s</xliff:g> ውስጥ እርምጃዎችን ማከናወን ይችላሉ።"</string>
    <string name="app_function_target_access_empty" msgid="2441713844910322045">"በአሁኑ ጊዜ ማናቸውም ተወካይ መተግበሪያዎች የሉዎትም።"</string>
</resources>
