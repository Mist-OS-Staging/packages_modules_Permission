<PreferenceScreen
    xmlns:android="http://schemas.android.com/apk/res/android">
    <com.android.settingslib.widget.IntroPreference
        android:key="intro" />
    <PreferenceCategory android:key="radio_button_category">
        <com.android.settingslib.widget.SelectorWithWidgetPreference
            android:key="allow"
            android:title="@string/manage_app_function_access_allow"/>
        <com.android.settingslib.widget.SelectorWithWidgetPreference
            android:key="dont_allow"
            android:title="@string/manage_app_function_access_dont_allow"/>
        </PreferenceCategory>
</PreferenceScreen>
