<resources>
    <!-- START REQUEST APP FUNCTION DIALOG -->

    <style name="RequestAppFunctionAccessDialogScrollView">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:paddingHorizontal">24dp</item>
        <item name="android:paddingTop">24dp</item>
        <item name="android:paddingBottom">16dp</item>
        <item name="android:background">@color/settingslib_materialColorSurfaceContainerHigh</item>
    </style>

    <style name="RequestAppFunctionAccessDialogContent">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:orientation">vertical</item>
        <item name="android:gravity">center_horizontal</item>
    </style>

    <style name="RequestAppFunctionAccessDialogIconBar">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:paddingTop">12dp</item>
        <item name="android:paddingEnd">4dp</item>
        <item name="android:gravity">center_horizontal</item>
        <item name="android:orientation">horizontal</item>
    </style>

    <style name="RequestAppFunctionAccessDialogAgentIcon">
        <item name="android:layout_width">60dp</item>
        <item name="android:layout_height">60dp</item>
        <item name="android:scaleType">fitCenter</item>
    </style>

    <style name="RequestAppFunctionAccessDialogTargetIcon">
        <item name="android:layout_width">60dp</item>
        <item name="android:layout_height">60dp</item>
        <item name="android:layout_marginStart">-10dp</item>
        <item name="android:scaleType">fitCenter</item>
    </style>

    <style name="RequestAppFunctionAccessDialogTitle">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginTop">24dp</item>
        <item name="android:layout_marginBottom">16dp</item>
        <item name="android:gravity">center_horizontal</item>
        <item name="android:textAppearance">@style/TextAppearance.SettingsLib.HeadlineSmall</item>
    </style>

    <style name="RequestAppFunctionAccessDialogDescription">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:gravity">start</item>
        <item name="android:lineSpacingMultiplier">1.2</item>
        <item name="android:textAppearance">@style/TextAppearance.SettingsLib.BodyMedium</item>
        <item name="android:textSize">14sp</item>
    </style>

    <style name="RequestAppFunctionAccessDialogAllowButton">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginTop">28dp</item>
        <item name="android:minHeight">@dimen/settingslib_expressive_space_medium3</item>
        <item name="android:background">@drawable/settingslib_expressive_button_background_filled</item>
        <item name="android:textAppearance">@style/TextAppearance.SettingsLib.LabelLarge</item>
        <item name="android:textColor">@color/settingslib_materialColorOnPrimary</item>
    </style>

    <style name="RequestAppFunctionAccessDialogDontAllowButton">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginTop">@dimen/settingslib_expressive_space_small1</item>
        <item name="android:layout_marginBottom">@dimen/settingslib_expressive_space_extrasmall4</item>
        <item name="android:minHeight">@dimen/settingslib_expressive_space_medium3</item>
        <item name="android:background">@drawable/settingslib_expressive_button_background_filled</item>
        <item name="android:textAppearance">@style/TextAppearance.SettingsLib.LabelLarge</item>
        <item name="android:textColor">@color/settingslib_materialColorOnPrimary</item>
    </style>

    <!-- END REQUEST APP FUNCTION DIALOG -->

    <!-- START REQUEST READ SCREEN CONTEXT DIALOG -->

    <style name="RequestReadScreenContextDialogScrollView">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:paddingHorizontal">@dimen/settingslib_expressive_space_small4</item>
        <item name="android:paddingTop">@dimen/settingslib_expressive_space_small4</item>
        <item name="android:paddingBottom">@dimen/settingslib_expressive_space_small4</item>
        <item name="android:background">@color/settingslib_materialColorSurfaceContainerHigh</item>
    </style>

    <style name="RequestReadScreenContextDialogContent">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:orientation">vertical</item>
        <item name="android:gravity">center_horizontal</item>
    </style>

    <style name="RequestReadScreenContextDialogAssistantIcon">
        <item name="android:layout_width">40dp</item>
        <item name="android:layout_height">40dp</item>
        <item name="android:layout_marginBottom">@dimen/settingslib_expressive_space_small1</item>
        <item name="android:gravity">center_horizontal</item>
        <item name="android:scaleType">fitCenter</item>
    </style>

    <style name="RequestReadScreenContextDialogTitle">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginBottom">@dimen/settingslib_expressive_space_small1</item>
        <item name="android:gravity">center_horizontal</item>
        <item name="android:textAppearance">@style/TextAppearance.SettingsLib.HeadlineSmall</item>
    </style>

    <style name="RequestReadScreenContextDialogDescription">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginBottom">@dimen/settingslib_expressive_space_small4</item>
        <item name="android:gravity">start</item>
        <item name="android:textAppearance">@style/TextAppearance.SettingsLib.BodyMedium</item>
        <item name="android:textSize">14sp</item>
    </style>

    <style name="RequestReadScreenContextDialogAllowButton">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginTop">@dimen/settingslib_expressive_space_extrasmall2</item>
        <item name="android:layout_marginBottom">@dimen/settingslib_expressive_space_extrasmall2</item>
        <item name="android:minHeight">@dimen/settingslib_expressive_space_medium3</item>
        <item name="android:background">@drawable/settingslib_expressive_button_background_filled</item>
        <item name="android:textAppearance">@style/TextAppearance.SettingsLib.LabelLarge</item>
        <item name="android:textColor">@color/settingslib_materialColorOnPrimary</item>
    </style>

    <style name="RequestReadScreenContextDialogDontAllowButton">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginTop">@dimen/settingslib_expressive_space_extrasmall6</item>
        <item name="android:layout_marginBottom">@dimen/settingslib_expressive_space_extrasmall2</item>
        <item name="android:minHeight">@dimen/settingslib_expressive_space_medium3</item>
        <item name="android:background">@drawable/settingslib_expressive_button_background_filled</item>
        <item name="android:textAppearance">@style/TextAppearance.SettingsLib.LabelLarge</item>
        <item name="android:textColor">@color/settingslib_materialColorOnPrimary</item>
    </style>

    <!-- END REQUEST READ SCREEN CONTEXT DIALOG -->

    <!-- START LOCATION PERMISSION GRANT DIALOG -->

    <style name="PermissionLocationAccuracyContainer">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginBottom">24dp</item>
    </style>

    <style name="PermissionLocationAccuracyRadioGroupNewLocationDesign">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:orientation">horizontal</item>
    </style>

    <style name="PermissionLocationAccuracyRadioNewLocationDesign">
        <item name="android:button">@null</item>
        <item name="android:drawableStart">@drawable/checkmark_circle</item>
        <item name="android:drawablePadding">8dp</item>
        <item name="android:layout_width">150dp</item>
        <item name="android:layout_height">match_parent</item>
        <item name="android:textColor">@color/location_radio_button_text_color</item>
        <item name="android:textAppearance">@style/TextAppearance.SettingsLib.LabelMedium.Emphasized</item>
        <item name="android:gravity">center_vertical|start</item>
    </style>

    <style name="PermissionLocationAccuracyRadioFineNewLocationDesign" parent="PermissionLocationAccuracyRadioNewLocationDesign">
        <item name="android:layout_marginEnd">10dp</item>
    </style>

    <style name="PermissionLocationAccuracySingleRadio">
        <item name="android:button">@null</item>
        <item name="android:layout_width">150dp</item>
        <item name="android:layout_height">match_parent</item>
        <item name="android:textColor">@color/location_radio_button_text_color</item>
        <item name="android:textAppearance">@style/TextAppearance.SettingsLib.LabelMedium.Emphasized</item>
        <item name="android:layout_gravity">center</item>
        <item name="android:gravity">center_horizontal</item>
    </style>

    <!-- END LOCATION PERMISSION GRANT DIALOG -->

    <!-- START GRANT LOCATION BUTTON PERMISSION DIALOG -->
    <style name="RequestLocationButtonPermissionsDialogScrollView">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:gravity">center</item>
        <item name="android:paddingHorizontal">@dimen/settingslib_expressive_space_small4</item>
        <item name="android:paddingTop">@dimen/settingslib_expressive_space_small4</item>
        <item name="android:paddingBottom">@dimen/settingslib_expressive_space_small4</item>
        <item name="android:background">@color/settingslib_materialColorSurfaceContainerHigh</item>
    </style>

    <style name="RequestLocationButtonPermissionsDialogContent">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:orientation">vertical</item>
        <item name="android:gravity">center</item>
    </style>

    <style name="RequestLocationButtonPermissionsDialogIcon">
        <item name="android:layout_width">32dp</item>
        <item name="android:layout_height">32dp</item>
        <item name="android:layout_marginBottom">12dp</item>
        <item name="android:tint">@android:color/system_accent1_600</item>
        <item name="android:scaleType">fitCenter</item>
    </style>

    <style name="RequestLocationButtonPermissionsDialogTitle">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:gravity">center_horizontal</item>
        <item name="android:layout_marginBottom">16dp</item>
        <item name="android:textAppearance">@style/TextAppearance.SettingsLib.HeadlineSmall</item>
    </style>

    <style name="RequestLocationButtonPermissionsDialogSubtitle">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:gravity">center_horizontal</item>
        <item name="android:layout_marginBottom">28dp</item>
        <item name="android:textAppearance">@style/TextAppearance.SettingsLib.BodyMedium</item>
    </style>

    <style name="RequestLocationButtonPermissionsDialogIllustration">
        <item name="android:button">@null</item>
        <item name="android:layout_width">150dp</item>
        <item name="android:layout_height">match_parent</item>
        <item name="android:textColor">@color/settingslib_materialColorOnPrimaryContainer</item>
        <item name="android:textAppearance">@style/TextAppearance.SettingsLib.LabelMedium.Emphasized</item>
        <item name="android:layout_gravity">center</item>
        <item name="android:gravity">center_horizontal</item>
        <item name="android:layout_marginBottom">28dp</item>
    </style>

    <style name="RequestLocationButtonPermissionsDialogAllowButton"
        parent="@style/RequestLocationButtonPermissionsDialogButton"/>

    <style name="RequestLocationButtonPermissionsDialogDontAllowButton"
        parent="@style/RequestLocationButtonPermissionsDialogButton"/>

    <style name="RequestLocationButtonPermissionsDialogButton"
        parent="@android:style/Widget.DeviceDefault.Button.Borderless.Colored">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">@dimen/settingslib_expressive_space_medium4</item>
        <item name="android:layout_marginTop">@dimen/settingslib_expressive_space_none</item>
        <item name="android:layout_marginStart">@dimen/settingslib_expressive_space_none</item>
        <item name="android:layout_marginEnd">@dimen/settingslib_expressive_space_none</item>
        <item name="android:layout_marginBottom">@dimen/settingslib_expressive_space_extrasmall4</item>
        <item name="android:paddingLeft">8dp</item>
        <item name="android:paddingRight">8dp</item>
        <item name="android:background">@drawable/settingslib_expressive_button_background_filled</item>
        <item name="android:textColor">@color/settingslib_materialColorOnPrimary</item>
    </style>
    <!-- END GRANT LOCATION BUTTON PERMISSION DIALOG -->
</resources>
